# Copie este arquivo para ".env.local" (que já é ignorado pelo git) e
# preencha com os valores do seu projeto Supabase: Settings → API.
#
# Sem essas variáveis, o app funciona normalmente em modo local (sem
# contas, sem sincronização) — nada quebra.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave da API da Anthropic (console.anthropic.com), usada pela funcionalidade
# "resolver por foto". Sem essa variável, a rota fica indisponível mas o
# resto do app funciona normalmente.
ANTHROPIC_API_KEY=

# Chave "service_role" do Supabase (Settings → API → service_role secret).
# NUNCA exponha essa chave no cliente — ela ignora Row Level Security e só
# deve ser usada em código server-only (hoje: o webhook do Stripe, para
# gravar o status da assinatura sem depender da sessão do usuário).
SUPABASE_SERVICE_ROLE_KEY=

# Assinaturas (Stripe). Sem essas variáveis, a rota de checkout fica
# indisponível e todo conteúdo "Premium" fica bloqueado — o resto do app
# funciona normalmente em modo gratuito.
# 1. Crie uma conta em dashboard.stripe.com (use as chaves de teste primeiro).
# 2. Crie um Produto "Premium" com um Preço recorrente (mensal ou anual) e
#    copie o ID do preço (começa com "price_").
# 3. Developers → API keys → Secret key.
# 4. Developers → Webhooks → adicione um endpoint para
#    "https://SEU_DOMINIO/api/stripe/webhook" com os eventos
#    checkout.session.completed, customer.subscription.updated e
#    customer.subscription.deleted — copie o "Signing secret".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# Notificações push (lembrete de sequência). Sem essas variáveis, o botão de
# ativar lembretes fica oculto e o resto do app funciona normalmente.
# Gere o par de chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# E-mail ou URL de contato, exigido pelo protocolo Web Push (ex: mailto:voce@exemplo.com)
VAPID_SUBJECT=
# Segredo compartilhado que protege /api/push/send-streak-reminders — só o
# agendador externo (cron) que dispara essa rota deve conhecê-lo.
CRON_SECRET=
