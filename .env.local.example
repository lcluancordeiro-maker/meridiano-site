# Copie este arquivo para ".env.local" (que já é ignorado pelo git) e
# preencha com os valores do seu projeto Supabase: Settings → API.
#
# Sem essas variáveis, o app funciona normalmente em modo local (sem
# contas, sem sincronização) — nada quebra.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave da API da Anthropic (console.anthropic.com), usada pela funcionalidade
# "resolver por foto". Sem essa variável, a rota fica indisponível mas o
# resto do app funciona normalmente.
ANTHROPIC_API_KEY=

# Chave "service_role" do Supabase (Settings → API → service_role secret).
# NUNCA exponha essa chave no cliente — ela ignora Row Level Security e só
# deve ser usada em código server-only (hoje: o webhook do Stripe, para
# gravar o status da assinatura sem depender da sessão do usuário).
SUPABASE_SERVICE_ROLE_KEY=

# Assinaturas (Stripe). Sem essas variáveis, a rota de checkout fica
# indisponível e todo conteúdo "Premium" fica bloqueado — o resto do app
# funciona normalmente em modo gratuito.
# 1. Crie uma conta em dashboard.stripe.com (use as chaves de teste primeiro).
# 2. Crie um Produto "Premium" com um Preço recorrente (mensal ou anual) e
#    copie o ID do preço (começa com "price_").
# 3. Developers → API keys → Secret key.
# 4. Developers → Webhooks → adicione um endpoint para
#    "https://SEU_DOMINIO/api/stripe/webhook" com os eventos
#    checkout.session.completed, customer.subscription.updated e
#    customer.subscription.deleted — copie o "Signing secret".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# Notificações push (lembrete de sequência). Sem essas variáveis, o botão de
# ativar lembretes fica oculto e o resto do app funciona normalmente.
# Gere o par de chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# E-mail ou URL de contato, exigido pelo protocolo Web Push (ex: mailto:voce@exemplo.com)
VAPID_SUBJECT=
# Segredo compartilhado que protege /api/push/send-streak-reminders — só o
# agendador externo (cron) que dispara essa rota deve conhecê-lo.
CRON_SECRET=

# URL pública canônica do deploy (ex: https://meridianomatematica.com.br).
# Usada para gerar o sitemap.xml, o robots.txt e as tags OpenGraph/Twitter
# com URLs absolutas corretas. Sem essa variável, cai em
# "http://localhost:3000" — nada quebra, mas o sitemap fica com URLs
# locais em produção.
NEXT_PUBLIC_SITE_URL=

# Monitoramento de erros (Sentry). Sem essas variáveis, o app roda
# normalmente e nenhum evento é enviado.
# 1. Crie um projeto Next.js em sentry.io e copie o DSN do projeto.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Analytics de página, sem cookies (compatível com Plausible). Sem essa
# variável, nenhum script de analytics é carregado.
# 1. Crie um site em plausible.io (ou rode uma instância própria/Umami) e
#    use o domínio cadastrado aqui.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Só necessário se você hospedar seu próprio Plausible/Umami — aponte para
# o script.js do seu servidor. Sem essa variável, usa o script.js oficial
# do plausible.io.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

# Verificação de identidade (Stripe Identity) — exigida antes de liberar
# chat, comunidades e lives. Sem essas variáveis, a verificação fica
# indisponível (e, portanto, chat/comunidades/lives também).
# 1. No dashboard da Stripe, ative o produto "Identity".
# 2. Developers → Webhooks → adicione um SEGUNDO endpoint (separado do de
#    assinaturas) para "https://SEU_DOMINIO/api/identity/webhook" com os
#    eventos identity.verification_session.verified,
#    identity.verification_session.requires_input e
#    identity.verification_session.canceled — copie o "Signing secret".
# Reaproveita STRIPE_SECRET_KEY (já configurado acima para assinaturas).
STRIPE_IDENTITY_WEBHOOK_SECRET=

# E-mail transacional (Resend), usado só para o link de consentimento dos
# responsáveis quando um usuário verificado é menor de idade. Sem essas
# variáveis, o link ainda é gerado e salvo no banco, mas nenhum e-mail é
# enviado de verdade — veja src/lib/email/resend.ts.
# 1. Crie uma conta em resend.com e verifique um domínio remetente.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Lives (vídeo ao vivo via LiveKit Cloud) — exige verificação de identidade
# (ver acima) para assistir, e assinatura Premium para hospedar. Sem essas
# variáveis, a página /lives fica indisponível e o resto do app funciona
# normalmente.
# 1. Crie um projeto em cloud.livekit.io.
# 2. Settings → Keys → copie a API Key e o API Secret.
# 3. Copie a "Project URL" (formato wss://SEU-PROJETO.livekit.cloud) — essa
#    URL é pública (usada pelo navegador para conectar na sala), por isso
#    fica em uma variável NEXT_PUBLIC_.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Grafo de conhecimento, Fase 2 (busca semântica) — opcional. Sem essa
# variável, o grafo de conhecimento (seção "Tópicos relacionados" nas
# páginas de tópico) usa só a curadoria manual em curriculum.ts. Com ela,
# um script offline (npm run generate-embeddings) gera embeddings de cada
# tópico via Voyage AI e grava no Postgres (extensão pgvector), permitindo
# achar tópicos relacionados por similaridade semântica de verdade.
# 1. Crie uma conta em voyageai.com e copie a API key.
# 2. Rode `supabase/schema.sql` de novo (habilita a extensão vector e cria
#    a tabela topic_embeddings).
# 3. Rode `npm run generate-embeddings` sempre que editar curriculum.ts
#    (precisa também de SUPABASE_SERVICE_ROLE_KEY, já configurado acima).
VOYAGE_API_KEY=
